# =============================================================================
# mcp_server
# =============================================================================

# Azure subscription ID (single subscription)
AZURE_SUBSCRIPTION_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Set to "true" to use mock data instead of real Azure APIs
USE_MOCK=true

# Managed Identity client ID (user-assigned) — required in production
AZURE_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# =============================================================================
# orchestrator
# =============================================================================

# Gemini API key
GEMINI_API_KEY=AIza...

# MCP Server URL (local: Azure Functions default port)
MCP_SERVER_URL=http://localhost:7071/mcp

# Azure Functions access key — required in production, omit for local dev
MCP_FUNCTION_KEY=

# Entra ID tenant ID
ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App Registration client ID
ENTRA_APP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Set to "true" to skip Entra ID JWT validation (local dev only)
SKIP_AUTH=true

# =============================================================================
# cli
# =============================================================================

# FastAPI base URL
ORCHESTRATOR_URL=http://localhost:8000

# Entra ID tenant ID (same as orchestrator)
# ENTRA_TENANT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# App Registration client ID (same as orchestrator)
# ENTRA_APP_CLIENT_ID=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx

# Set to "true" to skip authentication (local dev only)
# SKIP_AUTH=true
